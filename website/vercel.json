{
  "rewrites": [
    { "source": "/privacy", "destination": "/privacy/" },
    { "source": "/terms", "destination": "/terms/" },
    { "source": "/release-notes/1.0.6", "destination": "/release-notes/1.0.6/" },
    { "source": "/release-notes/1.0.7", "destination": "/release-notes/1.0.7/" }
  ],
  "redirects": [
    {
      "source": "/download",
      "destination": "https://github.com/JeeT001/FrameFlow/releases/download/v1.0.7/Drazlo-1.0.7.dmg",
      "permanent": false
    },
    {
      "source": "/downloads/Drazlo-:version.dmg",
