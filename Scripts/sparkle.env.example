# Copy to sparkle.env (gitignored) if not using macOS Keychain for EdDSA signing.
# Usage: set -a && source Scripts/sparkle.env && set +a
#
# Preferred: run Sparkle generate_keys once — private key stays in Keychain;
# sign_update works without SPARKLE_EDDSA_PRIVATE_KEY_FILE.
#
# Alternative: export private key file path after generate_keys:
# export SPARKLE_EDDSA_PRIVATE_KEY_FILE="$HOME/.sparkle/drazlo_eddsa_private.key"
# export SPARKLE_BIN_DIR="$HOME/Library/Developer/Xcode/DerivedData/.../Sparkle/bin"
