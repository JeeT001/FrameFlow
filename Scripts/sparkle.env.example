# Copy to sparkle.env (gitignored) and fill in locally. Never commit real private keys.
# Usage: set -a && source Scripts/sparkle.env && set +a && ./Scripts/sign_sparkle_update.sh build/Drazlo-1.0.dmg

# Directory containing Sparkle release utilities (generate_keys, sign_update).
# Download from https://github.com/sparkle-project/Sparkle/releases (Sparkle-*-tar.xz, extract bin/).
# export SPARKLE_BIN_DIR="$HOME/Tools/Sparkle/bin"

# EdDSA private key file from `./generate_keys` (default: ~/.sparkle/drazlo_eddsa_private.key)
# export SPARKLE_EDDSA_PRIVATE_KEY_FILE="$HOME/.sparkle/drazlo_eddsa_private.key"

# Optional inline private key (avoid on shared machines):
# export SPARKLE_EDDSA_PRIVATE_KEY="..."
