# Copy to notary.env (gitignored) and fill in locally. Never commit real values.
# Usage: set -a && source Scripts/notary.env && set +a && ./Scripts/notarize_app.sh
#
# GitHub Actions uses the same variables — see Scripts/github-secrets.example
# and Docs/RELEASE_SIGNING.md (Day 49).

export NOTARY_APPLE_ID="you@example.com"
export NOTARY_TEAM_ID="6XP66CQ82V"
export NOTARY_APP_PASSWORD="xxxx-xxxx-xxxx-xxxx"
# Or store in Keychain: export NOTARY_APP_PASSWORD="@keychain:AC_PASSWORD"
