# GitHub Actions secrets for .github/workflows/release.yml
# Configure in: Repository → Settings → Secrets and variables → Actions
# Never commit real values. See Docs/RELEASE_SIGNING.md (Day 49).

# CERTIFICATES_P12              Base64-encoded Developer ID Application .p12
# CERTIFICATES_P12_PASSWORD     Password for the .p12 export
# APPLE_ID                      Apple ID email → NOTARY_APPLE_ID in scripts
# TEAM_ID                       Apple Team ID (6XP66CQ82V)
# APPLE_APP_PASSWORD            App-specific password → NOTARY_APP_PASSWORD

# Optional (Day 48 Sparkle appcast automation — not wired in CI yet):
# SPARKLE_EDDSA_PRIVATE_KEY     EdDSA private key for sign_sparkle_update.sh

# Export .p12 as base64 (run locally, paste into GitHub secret):
#   base64 -i DeveloperID.p12 | pbcopy
